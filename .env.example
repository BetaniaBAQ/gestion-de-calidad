# =============================================================================
#  GUÍA DE CONFIGURACIÓN — Cualia SGC
#  Copia este archivo como ".env.local" en la raíz del proyecto y llena
#  cada variable siguiendo las instrucciones de cada sección.
#
#  NUNCA subas .env.local a git. Ya está en .gitignore.
# =============================================================================


# =============================================================================
#  SECCIÓN 1 — CONVEX (base de datos y backend en tiempo real)
# =============================================================================
#
#  Convex es la base de datos del proyecto. Necesitas crear un proyecto en
#  su dashboard y luego inicializar el deployment desde tu terminal.
#
#  PASO 1 — Crea una cuenta en https://dashboard.convex.dev
#  PASO 2 — Crea un nuevo proyecto (dale cualquier nombre, ej. "cualia-dev")
#  PASO 3 — Desde la raíz del monorepo, corre:
#
#    cd packages/convex
#    npx convex dev
#
#  Ese comando abre el browser, te pide hacer login con tu cuenta de Convex,
#  y luego te pregunta qué proyecto usar. Selecciona el que creaste.
#
#  Al terminar, Convex crea automáticamente un archivo "convex.json" en
#  packages/convex/ y también escribe CONVEX_DEPLOYMENT en tu .env.local.
#  Copia esos valores aquí.
#
# CONVEX_DEPLOYMENT — Nombre interno del deployment
#   Formato: "dev:nombre-proyecto-abc123"
#   Se genera automáticamente al correr "npx convex dev"
#   Ejemplo: dev:cualia-dev-abc123

CONVEX_DEPLOYMENT=

#
# VITE_CONVEX_URL — URL pública del deployment (la usa el browser y el servidor)
#   Formato: "https://xxxxx.convex.cloud"
#   La encuentras en: Convex Dashboard → tu proyecto → Settings → Deployment URL
#   O en la salida del comando "npx convex dev" (línea "Convex URL:")
#   Ejemplo: https://happy-animal-123.convex.cloud

VITE_CONVEX_URL=

#
#  PASO 4 — Configura las variables de entorno en Convex para autenticación:
#
#    cd packages/convex
#    npx convex env set WORKOS_CLIENT_ID client_TU_CLIENT_ID_AQUI
#
#  Esto es necesario para que Convex pueda verificar los tokens de WorkOS.
#  (Ver Sección 2 para obtener el WORKOS_CLIENT_ID)


# =============================================================================
#  SECCIÓN 2 — WORKOS (autenticación y multi-tenancy)
# =============================================================================
#
#  WorkOS maneja el login, las organizaciones (tenants) y los roles de usuario.
#  Usa su producto "AuthKit" para la autenticación de usuarios.
#
#  PASO 1 — Crea una cuenta en https://dashboard.workos.com
#  PASO 2 — En el dashboard, ve a "API Keys" (menú lateral izquierdo)
#
# WORKOS_API_KEY — Clave secreta del servidor (NUNCA la expongas al browser)
#   Formato: "sk_live_xxxx" (producción) o "sk_test_xxxx" (desarrollo)
#   Ubicación: WorkOS Dashboard → API Keys → "Secret Key"
#   ⚠️  Esta clave solo va aquí, NUNCA empieces el nombre con VITE_ porque
#       eso la expondría al browser
#   Ejemplo: sk_test_abc123def456

WORKOS_API_KEY=

#
#  PASO 3 — Ve a "Applications" en el sidebar y crea o selecciona tu app
#
# WORKOS_CLIENT_ID — Identificador público de tu aplicación en WorkOS
# VITE_WORKOS_CLIENT_ID — El mismo valor, expuesto al browser para iniciar auth
#   Formato: "client_xxxx"
#   Ubicación: WorkOS Dashboard → Applications → tu app → "Client ID"
#   Nota: WORKOS_CLIENT_ID y VITE_WORKOS_CLIENT_ID deben tener el MISMO valor.
#         Necesitamos los dos porque uno lo usa el servidor y otro el browser.
#   Ejemplo: client_01HXK8MNPQRS

WORKOS_CLIENT_ID=
VITE_WORKOS_CLIENT_ID=

#
#  PASO 4 — Configura las URLs de redirección en tu aplicación de WorkOS:
#            WorkOS Dashboard → Applications → tu app → Redirects
#            Agrega estas URLs:
#              Desarrollo:  http://localhost:3000/auth/callback
#              Producción:  https://tu-dominio.cualia.app/auth/callback
#
# WORKOS_REDIRECT_URI — URL a la que WorkOS redirige después del login
#   Debe coincidir EXACTAMENTE con lo que registraste en el dashboard de WorkOS.
#   Para desarrollo local usa http://localhost:3000/auth/callback
#   Para producción cambia por tu URL real.

WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

#
# WORKOS_COOKIE_SECRET — Secreto para cifrar las cookies de sesión del servidor
#   Requisito: mínimo 32 caracteres aleatorios
#   Generación rápida (corre esto en tu terminal):
#
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   O en macOS/Linux:
#
#     openssl rand -hex 32
#
#   Guarda el resultado aquí. Este valor debe ser diferente en cada entorno
#   (dev, staging, producción).
#   Ejemplo: a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

WORKOS_COOKIE_SECRET=


# =============================================================================
#  NOTAS FINALES
# =============================================================================
#
#  Una vez llenes todas las variables:
#
#  1. Inicia Convex en desarrollo (en una terminal):
#       cd packages/convex && npx convex dev
#
#  2. Inicia la app (en otra terminal):
#       pnpm dev
#
#  Si algo falla al arrancar, el error te dirá exactamente qué variable falta.
#
#  Para producción (Vercel), agrega cada variable en:
#  Vercel Dashboard → tu proyecto → Settings → Environment Variables
# =============================================================================

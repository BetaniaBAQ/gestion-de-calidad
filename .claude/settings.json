{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "TodoRead",
      "TodoWrite",
      "Task"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(chmod -R *)",
      "Bash(sudo *)"
    ],
    "deny": [
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(fdisk *)",
      "Bash(curl *|bash*)",
      "Bash(curl *| bash*)",
      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(> /*)",
      "Bash(shred *)"
    ]
  }
}

{
  "include": [
    "src/**/*",
    ".tanstack/**/*",
    "**/*.ts",
    "**/*.tsx",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    // baseUrl ha sido eliminado
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true, 
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true
    // ... resto de tus reglas
  }
}
